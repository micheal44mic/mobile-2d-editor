{
  "compilerOptions": {
    "allowJs": false,
    "isolatedModules": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "target": "ESNext",
    "types": ["@webgpu/types"]
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"]
}
